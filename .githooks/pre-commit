#!/bin/bash
# Pre-commit hook: lint staged files with Biome and type-check
#
# NOTE: For code review, run `copilot review this code` after staging
# to invoke the code-reviewer agent (Claude Sonnet 4.6) before committing.

set -e

echo "🔍 Running Biome lint on staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -n "$STAGED_FILES" ]; then
  npx biome check --no-errors-on-unmatched $STAGED_FILES
fi

echo "🔍 Type-checking..."
npx tsc --noEmit

echo "✅ Pre-commit checks passed"
